    "def experiment_1_keras():\n",
    "    X = train_data.drop(columns=[\"state\"])\n",
    "    y = train_data[\"state\"]\n",
    "    y_binary = y.replace({\"n\": \"asleep\", \"r\": \"asleep\", \"w\": \"awake\"})\n",
    "    le = LabelEncoder()\n",
    "    encoded = le.fit_transform(y_binary)\n",
    "    y_binary = pd.Series(encoded, index=y_binary.index)\n",
    "    hist, mlps = train_keras(X, y_binary)\n",
    "    return hist, mlps, X, y_binary, le"
   ]
