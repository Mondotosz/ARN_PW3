  {
   "cell_type": "markdown",
   "id": "dd41fbe5",
   "metadata": {},
   "source": [
    "### Validation:\n",
    "\n",
    "- Use 3-fold cross-validation and shuffle data\n",
    "\n",
    "**Note**: we shuffle the data but it's not a perfect solution. In that way, with two data points that\n",
    "are few seconds apart, one could be in training set and the other one in validation, which\n",
    "means that the validation will be highly correlated with the training and would not represent\n",
    "reliably the model's performance on unknown data. If we split data without shuffling, we\n",
    "would have folds with nearly only awake state which would not be desirable as well.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "945fee72",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "WARNING: All log messages before absl::InitializeLog() is called are written to STDERR\n",
      "I0000 00:00:1774610995.247934  266082 cpu_feature_guard.cc:227] This TensorFlow binary is optimized to use available CPU instructions in performance-critical operations.\n",
      "To enable the following instructions: AVX2 FMA, in other operations, rebuild TensorFlow with the appropriate compiler flags.\n"
     ]
    }
   ],
   "source": [
    "from sklearn.model_selection import KFold\n",
    "from sklearn.metrics import (\n",
    "    accuracy_score,\n",
    "    classification_report,\n",
    "    confusion_matrix,\n",
    "    f1_score,\n",
    ")\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "from secrets import randbits\n",
    "import keras\n",
    "from keras import layers, models\n",
    "from matplotlib import pyplot as plt\n",
    "from tqdm.keras import TqdmCallback\n",
    "from keras.callbacks import EarlyStopping\n",
    "\n",
    "# Create 3-fold cross-validation with shuffling\n",
    "kfold = KFold(n_splits=3, shuffle=True, random_state=randbits(32))\n",
    "\n",
    "keras.utils.set_random_seed(randbits(32))\n",
    "\n",
    "\n",
    "def create_keras_model(num_classes, shape=(25,), activation=\"tanh\"):\n",
    "    model = models.Sequential(\n",
    "        [\n",
    "            layers.Input(shape=shape),\n",
    "            layers.Dense(100, activation=activation),\n",
    "            layers.Dense(50, activation=activation),\n",
    "            layers.Dense(\n",
    "                1 if num_classes <= 2 else num_classes,\n",
    "                activation=\"sigmoid\" if num_classes <= 2 else \"softmax\",\n",
    "            ),\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    model.compile(\n",
    "        optimizer=\"adam\",\n",
    "        loss=(\n",
    "            \"binary_crossentropy\"\n",
    "            if num_classes <= 2\n",
    "            else \"sparse_categorical_crossentropy\"\n",
    "        ),\n",
    "        metrics=[\"accuracy\"],\n",
    "    )\n",
    "    return model\n",
    "\n",
    "\n",
    "def train_keras(X, y, early_stopping=True):\n",
    "    hist = []\n",
    "    mlps = []\n",
    "\n",
    "    X_np = X.values.astype(np.float32)\n",
    "    y_np = y.values.astype(np.int32)\n",
    "\n",
    "    fold_indices = list(kfold.split(X_np))\n",
    "    num_classes = len(np.unique(y_np))\n",
    "    shape = (X_np.shape[1],)\n",
    "    fold_pbar = tqdm(total=kfold.get_n_splits(), desc=\"K-Folds\")\n",
    "\n",
    "    early_stop = EarlyStopping(monitor='val_loss', patience=10, restore_best_weights=True) if early_stopping else None\n",
    "\n",
    "    for train_idx, val_idx in fold_indices:\n",
    "        mlp = create_keras_model(num_classes=num_classes, shape=shape)\n",
    "        history = mlp.fit(\n",
    "            x=X_np[train_idx],\n",
    "            y=y_np[train_idx],\n",
    "            validation_data=(X_np[val_idx], y_np[val_idx]),\n",
    "            epochs=100,\n",
    "            batch_size=32,\n",
    "            verbose=0,\n",
    "            callbacks=[TqdmCallback(verbose=0), early_stop],\n",
    "        )\n",
    "\n",
    "        hist.append(history)\n",
    "\n",
    "        fold_pbar.update(1)\n",
    "        fold_pbar.set_postfix(\n",
    "            {\n",
    "                \"loss\": history.history[\"loss\"][-1],\n",
    "                \"val_loss\": history.history[\"val_loss\"][-1],\n",
    "                \"epochs\": len(history.epoch),\n",
    "            }\n",
    "        )\n",
    "        mlps.append(mlp)\n",
    "\n",
    "    fold_pbar.close()\n",
    "    return hist, mlps\n",
    "\n",
    "\n",
    "def plot_keras_history(hist):\n",
    "    max_epochs = max(len(h.history[\"loss\"]) for h in hist)\n",
    "    num_folds = len(hist)\n",
    "\n",
    "    train_losses = np.full((num_folds, max_epochs), np.nan)\n",
    "    val_losses = np.full((num_folds, max_epochs), np.nan)\n",
    "\n",
    "    for i, h in enumerate(hist):\n",
    "        epochs_run = len(h.history[\"loss\"])\n",
    "        train_losses[i, :epochs_run] = h.history[\"loss\"]\n",
    "        val_losses[i, :epochs_run] = h.history[\"val_loss\"]\n",
    "\n",
    "    # Calculate mean and standard deviation for training and validation losses\n",
    "    mean_train_loss = np.nanmean(train_losses, axis=0)\n",
    "    std_train_loss = np.nanstd(train_losses, axis=0)\n",
    "    mean_val_loss = np.nanmean(val_losses, axis=0)\n",
    "    std_val_loss = np.nanstd(val_losses, axis=0)\n",
    "\n",
    "    # Plot mean and standard deviation for training loss\n",
    "    plt.plot(mean_train_loss, label=\"Training Loss (Mean)\")\n",
    "    plt.fill_between(\n",
    "        range(len(mean_train_loss)),\n",
    "        mean_train_loss - std_train_loss,\n",
    "        mean_train_loss + std_train_loss,\n",
    "        alpha=0.3,\n",
    "        label=\"Training Loss (Std)\",\n",
    "    )\n",
    "\n",
    "    # Plot mean and standard deviation for validation loss\n",
    "    plt.plot(mean_val_loss, label=\"Validation Loss (Mean)\")\n",
    "    plt.fill_between(\n",
    "        range(len(mean_val_loss)),\n",
    "        mean_val_loss - std_val_loss,\n",
    "        mean_val_loss + std_val_loss,\n",
    "        alpha=0.3,\n",
    "        label=\"Validation Loss (Std)\",\n",
    "    )\n",
    "\n",
    "    # Add labels and legend\n",
    "    plt.xlabel(\"Epochs\")\n",
    "    plt.ylabel(\"Loss\")\n",
    "    plt.legend()\n",
    "\n",
    "    # Display the plot\n",
    "    plt.show()\n",
    "\n",
    "def plot_confusion_matrix(confusion_matrix, title):\n",
    "    # Plot confusion matrix\n",
    "    plt.figure(figsize=(8, 6))\n",
    "    sns.heatmap(confusion_matrix.astype(int), annot=True, fmt=\"d\", cmap=\"Blues\", cbar=False,\n",
    "                xticklabels=[\"Blue\", \"Red\"], yticklabels=[\"Blue\", \"Red\"])\n",
    "    plt.title(title)\n",
    "    plt.xlabel('Predicted')\n",
    "    plt.ylabel('True')\n",
    "    plt.show()\n",
    "\n",
    "def plot_performances(trained_mlp, input_data, output_data):\n",
    "    f1_scores = []\n",
    "    mean_confusion_matrix = np.zeros((2, 2))\n",
    "\n",
    "    X_eval = input_data.values.astype(np.float32)\n",
    "    y_eval = output_data.values.astype(np.int32)\n",
    "\n",
    "    for i, (train_index, test_index) in enumerate(kfold.split(input_data)):\n",
    "        # Evaluate the trained model on the test fold\n",
    "        probs = trained_mlp[i].predict(X_eval[test_index], verbose=0)\n",
    "        predictions = (probs > 0.5).astype(int).flatten()\n",
    "        true_labels = y_eval[test_index]\n",
    "\n",
    "        # Compute confusion matrix\n",
    "        cm = confusion_matrix(true_labels, predictions)\n",
    "        mean_confusion_matrix += cm\n",
    "\n",
    "        # Compute confusion matrix and plot\n",
    "        plot_confusion_matrix(cm, f'Confusion Matrix - Fold {i + 1}')\n",
    "\n",
    "        # Compute F1 score\n",
    "        f1 = f1_score(true_labels, predictions)\n",
    "        f1_scores.append(f1)\n",
    "        print(f\"F1 Score - Fold {i + 1}: {f1}\")\n",
    "\n",
    "    # Plot mean confusion matrix\n",
    "    plot_confusion_matrix(mean_confusion_matrix, 'Global confusion matrix')\n",
    "\n",
    "    # Calculate and display the mean F1 score across all folds\n",
    "    mean_f1_score = np.mean(f1_scores)\n",
    "    print(f\"Mean F1 Score across all folds: {mean_f1_score}\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "7f3acc75",
   "metadata": {},
   "source": [
    "### Training history: \n",
    "- Plot training and validation loss "
   ]
  },
